{
  "name": "linkrescue",
  "version": "1.1.0",
  "description": "Find broken affiliate links on any website. No signup, no API key, works on any stack. Respects robots.txt.",
  "bin": {
    "linkrescue": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "broken-links",
    "link-checker",
    "affiliate",
    "seo",
    "cli"
  ],
  "license": "MIT",
  "author": "LinkRescue <hello@linkrescue.io>",
  "homepage": "https://linkrescue.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carsonlabs/linkrescue.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/carsonlabs/linkrescue/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@linkrescue/crawler": "workspace:*",
    "@linkrescue/types": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "tsup": "^8.4.0",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.17"
  }
}
