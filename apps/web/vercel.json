{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm build",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "packageManager": "pnpm@8.15.4",
  "crons": [
    {
      "path": "/api/cron/scan",
      "schedule": "0 * * * *"
    }
  ]
}
