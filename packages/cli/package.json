  "author": "LinkRescue <hello@linkrescue.io>",
  "homepage": "https://linkrescue.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linkrescue/linkrescue.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@linkrescue/crawler": "workspace:*",
    "@linkrescue/types": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.17"
  }
}
