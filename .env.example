# LinkRescue Environment Variables
# -----------------------------------
# Copy this file to .env and fill in the values.

# Supabase
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY="" # For server-side operations

# Stripe
# Get these from your Stripe dashboard > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET="" # Get from Developers > Webhooks > Signing secret
STRIPE_PRO_PRICE_ID="" # The Price ID for the Pro plan (e.g., price_xxx)

# Resend (Email)
# Get this from your Resend dashboard > API Keys
RESEND_API_KEY=""

# Vercel Cron
# A secret string to protect your cron endpoint. Generate a strong random string.
CRON_SECRET=""

# App Configuration
# The base URL of your deployed application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
