{
  "name": "@linkrescue/sdk",
  "version": "1.0.0",
  "description": "Official Node.js/TypeScript SDK for the LinkRescue API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": ["linkrescue", "broken-links", "affiliate", "link-checker", "seo", "api"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/linkrescue/linkrescue"
  }
}
