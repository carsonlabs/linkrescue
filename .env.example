# LinkRescue Environment Variables
# -----------------------------------
# Copy this file to .env and fill in the values.

# Supabase
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY="" # For server-side operations

# Stripe
# Get these from your Stripe dashboard > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET="" # Get from Developers > Webhooks > Signing secret

# Stripe Price IDs — create these in the Stripe Dashboard
# Pro plan
STRIPE_PRO_MONTHLY_PRICE_ID=""   # Monthly Pro ($29/mo)
STRIPE_PRO_ANNUAL_PRICE_ID=""    # Annual Pro ($290/yr)
# Agency plan
STRIPE_AGENCY_MONTHLY_PRICE_ID="" # Monthly Agency ($79/mo)
STRIPE_AGENCY_ANNUAL_PRICE_ID=""  # Annual Agency ($790/yr)

# Legacy aliases (still supported for backward compatibility)
# STRIPE_PRO_PRICE_ID=""
# STRIPE_AGENCY_PRICE_ID=""

# Resend (Email)
# Get this from your Resend dashboard > API Keys
RESEND_API_KEY=""

# Vercel Cron
# A secret string to protect your cron endpoint. Generate a strong random string.
CRON_SECRET=""

# Rewardful (Affiliate Program)
# Get these from your Rewardful dashboard
NEXT_PUBLIC_REWARDFUL_API_KEY=""       # Tracking script API key
NEXT_PUBLIC_REWARDFUL_SIGNUP_URL=""    # Affiliate signup page URL

# App Configuration
# The base URL of your deployed application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
