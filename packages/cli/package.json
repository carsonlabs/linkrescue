{
  "name": "linkrescue",
  "version": "1.0.0",
  "description": "Find broken links and affiliate parameter issues on any website",
  "bin": {
    "linkrescue": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
