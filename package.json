    "tsx": "^4.21.0",
    "turbo": "^1.12.4",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=7.24.0",
      "socket.io-parser": ">=4.2.6",
      "serialize-javascript": ">=7.0.3",
      "editorconfig>minimatch": ">=9.0.7",
      "fast-xml-parser": ">=5.5.7",
      "prismjs": ">=1.30.0"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
